---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;

// Google Drive links — one per project (in order)
// ADD MORE PROJECTS HERE
const driveLinks: string[] = [
  "#", // REPLACE WITH GOOGLE DRIVE LINK — La Diperie Inventory Optimization Model
  "#", // REPLACE WITH GOOGLE DRIVE LINK — La Diperie & La Fayette 16-Week Resource Scheduler
  "#", // REPLACE WITH GOOGLE DRIVE LINK — La Diperie Financial Reporting Dashboard
];
---

{
  hasProjects && (
    <section id="projects" class="projects-section">
      {/* ── Progress bar (3px, top of section) ── */}
      <div class="progress-track">
        <div class="progress-fill" id="proj-progress" />
      </div>

      <div class="projects-inner">
        {/* ── Section heading ── */}
        <div class="projects-heading">
          <h2 class="section-title">Projects</h2>
          <div class="accent-underline" />
        </div>

        {/* ── Tab navigation ── */}
        <nav class="proj-tabs" role="tablist" aria-label="Projects">
          {siteConfig.projects.map((proj, i) => (
            <button
              class={`proj-tab${i === 0 ? " active" : ""}`}
              data-index={String(i)}
              id={`proj-tab-${i}`}
              role="tab"
              aria-selected={i === 0 ? "true" : "false"}
              type="button"
            >
              {proj.category}
            </button>
          ))}
        </nav>

        {/* ── Stage + side arrows ── */}
        <div class="stage-wrapper">
          {/* Left arrow */}
          <button
            class="nav-arrow arrow-prev"
            id="proj-prev"
            aria-label="Previous project"
            type="button"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M15 18l-6-6 6-6" />
            </svg>
          </button>

          {/* Cards stage */}
          <div class="proj-stage" id="proj-stage">
            {siteConfig.projects.map((proj, i) => (
              <div
                class={`proj-card${i === 0 ? " is-active" : ""}`}
                data-index={String(i)}
                role="tabpanel"
                aria-labelledby={`proj-tab-${i}`}
              >
                {/* Category pill */}
                <span class="cat-pill">{proj.category}</span>

                {/* Title */}
                <h3 class="proj-title">{proj.name}</h3>

                {/* Description */}
                <p class="proj-desc">{proj.description}</p>

                {/* Skill chips */}
                <div class="proj-skills">
                  {proj.skills.map((skill) => (
                    <span class="skill-chip">{skill}</span>
                  ))}
                </div>

                {/* Google Drive button */}
                <a
                  href={driveLinks[i]}
                  class="drive-btn"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {/* Google Drive inline SVG icon */}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 87.3 78"
                    width="18"
                    height="18"
                    aria-hidden="true"
                    style="flex-shrink:0"
                  >
                    <path
                      d="m6.6 66.85 3.85 6.65c.8 1.4 1.95 2.5 3.3 3.3l13.75-23.8h-27.5c0 1.55.4 3.1 1.2 4.5z"
                      fill="#0066da"
                    />
                    <path
                      d="m43.65 25-13.75-23.8c-1.35.8-2.5 1.9-3.3 3.3l-25.4 44a9.06 9.06 0 0 0 -1.2 4.5h27.5z"
                      fill="#00ac47"
                    />
                    <path
                      d="m73.55 76.8c1.35-.8 2.5-1.9 3.3-3.3l1.6-2.75 7.65-13.25c.8-1.4 1.2-2.95 1.2-4.5h-27.502l5.852 11.5z"
                      fill="#ea4335"
                    />
                    <path
                      d="m43.65 25 13.75-23.8c-1.35-.8-2.9-1.2-4.5-1.2h-18.5c-1.6 0-3.15.45-4.5 1.2z"
                      fill="#00832d"
                    />
                    <path
                      d="m59.8 53h-32.3l-13.75 23.8c1.35.8 2.9 1.2 4.5 1.2h50.8c1.6 0 3.15-.45 4.5-1.2z"
                      fill="#2684fc"
                    />
                    <path
                      d="m73.4 26.5-12.7-22c-.8-1.4-1.95-2.5-3.3-3.3l-13.75 23.8 16.15 28h27.45c0-1.55-.4-3.1-1.2-4.5z"
                      fill="#ffba00"
                    />
                  </svg>
                  View on Google Drive
                </a>
              </div>
            ))}
          </div>

          {/* Right arrow */}
          <button
            class="nav-arrow arrow-next"
            id="proj-next"
            aria-label="Next project"
            type="button"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M9 18l6-6-6-6" />
            </svg>
          </button>
        </div>

        {/* Dot indicators (mobile-friendly alternative progress) */}
        <div class="proj-dots" aria-hidden="true">
          {siteConfig.projects.map((_, i) => (
            <span class={`proj-dot${i === 0 ? " active" : ""}`} data-index={String(i)} />
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  /* ── Section shell ── */
  .projects-section {
    position: relative;
    background: #ffffff;
    z-index: 1;
    overflow-x: hidden;
    padding-bottom: 5rem;
  }

  /* ── 3px progress bar ── */
  .progress-track {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: #e5e7eb;
    z-index: 10;
  }

  .progress-fill {
    height: 100%;
    background: #2b3fff;
    width: 0%;
    /* transition set by JS so initial paint is instant */
  }

  /* ── Inner container (centred) ── */
  .projects-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 4.5rem 1.5rem 0;
  }

  /* ── Section heading ── */
  .projects-heading {
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #111827;
    font-family: "IBM Plex Mono", monospace;
    line-height: 1.1;
  }

  .accent-underline {
    width: 75px;
    height: 5px;
    background: #2b3fff;
    border-radius: 9999px;
    margin-top: 0.5rem;
  }

  /* ── Tab navigation ── */
  .proj-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .proj-tab {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    border: 1.5px solid #d1d5db;
    background: transparent;
    color: #6b7280;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
    white-space: nowrap;
  }

  .proj-tab:hover {
    border-color: #2b3fff;
    color: #2b3fff;
  }

  .proj-tab.active {
    border-color: #2b3fff;
    background: rgba(43, 63, 255, 0.07);
    color: #2b3fff;
  }

  /* ── Stage wrapper (arrows + stage) ── */
  .stage-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* ── Navigation arrows ── */
  .nav-arrow {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid #d1d5db;
    background: #ffffff;
    color: #6b7280;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
    z-index: 2;
  }

  .nav-arrow:hover {
    border-color: #2b3fff;
    color: #2b3fff;
    box-shadow: 0 0 0 3px rgba(43, 63, 255, 0.1);
  }

  .nav-arrow:disabled {
    opacity: 0.3;
    pointer-events: none;
  }

  /* ── Cards stage ── */
  .proj-stage {
    position: relative;
    flex: 1;
    overflow: hidden;
    min-height: 520px;
    border-radius: 1.25rem;
  }

  @media (max-width: 640px) {
    .proj-stage {
      min-height: 640px;
    }
  }

  /* ── Individual project card ── */
  .proj-card {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: 2.5rem 2.75rem;
    background: #f9fafb;
    border-radius: 1.25rem;
    border: 1.5px solid #e5e7eb;
    /* Default: off-screen right, invisible */
    transform: translateX(100%);
    opacity: 0;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  @media (max-width: 640px) {
    .proj-card {
      padding: 1.75rem 1.5rem;
    }
  }

  .proj-card.is-active {
    transform: translateX(0);
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Category pill ── */
  .cat-pill {
    display: inline-block;
    padding: 0.25rem 0.85rem;
    background: rgba(43, 63, 255, 0.08);
    color: #2b3fff;
    border: 1px solid rgba(43, 63, 255, 0.22);
    border-radius: 9999px;
    font-size: 0.68rem;
    font-weight: 600;
    font-family: "IBM Plex Mono", monospace;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    align-self: flex-start;
  }

  /* ── Project title ── */
  .proj-title {
    font-family: "IBM Plex Mono", monospace;
    font-size: clamp(1.1rem, 2.5vw, 1.45rem);
    font-weight: 700;
    color: #111827;
    line-height: 1.35;
    margin-bottom: 1.1rem;
  }

  /* ── Description ── */
  .proj-desc {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.88rem;
    color: #4b5563;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  /* ── Skill chips ── */
  .proj-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 2rem;
  }

  .skill-chip {
    padding: 0.22rem 0.6rem;
    background: #111827;
    color: #ffffff;
    border-radius: 0.375rem;
    font-size: 0.68rem;
    font-weight: 500;
    font-family: "IBM Plex Mono", monospace;
    letter-spacing: 0.02em;
  }

  /* ── Google Drive button ── */
  .drive-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    align-self: flex-start;
    padding: 0.6rem 1.2rem;
    border: 1.5px solid #2b3fff;
    border-radius: 0.5rem;
    background: transparent;
    color: #2b3fff;
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .drive-btn:hover {
    background: #2b3fff;
    color: #ffffff;
  }

  /* ── Dot indicators ── */
  .proj-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .proj-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #d1d5db;
    transition: background 0.2s ease, transform 0.2s ease;
    display: block;
  }

  .proj-dot.active {
    background: #2b3fff;
    transform: scale(1.3);
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    var DURATION = 400; // transition duration in ms

    var cards = Array.from(document.querySelectorAll(".proj-card"));
    var tabs = Array.from(document.querySelectorAll(".proj-tab"));
    var dots = Array.from(document.querySelectorAll(".proj-dot"));
    var prevBtn = document.getElementById("proj-prev");
    var nextBtn = document.getElementById("proj-next");
    var progressEl = document.getElementById("proj-progress");

    var current = 0;
    var total = cards.length;
    var isTransitioning = false;

    // ── Progress bar animation ──────────────────────────────────
    function animateProgress() {
      progressEl.style.transition = "none";
      progressEl.style.width = "0%";
      // Double rAF ensures the "none" transition is painted before re-enabling
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          progressEl.style.transition = "width " + DURATION + "ms ease";
          progressEl.style.width = "100%";
        });
      });
    }

    // ── Update active tab + dots ────────────────────────────────
    function updateNav(idx) {
      tabs.forEach(function (t, i) {
        t.classList.toggle("active", i === idx);
        t.setAttribute("aria-selected", i === idx ? "true" : "false");
      });
      dots.forEach(function (d, i) {
        d.classList.toggle("active", i === idx);
      });
      if (prevBtn) prevBtn.disabled = idx === 0;
      if (nextBtn) nextBtn.disabled = idx === total - 1;
    }

    // ── Core go-to function ──────────────────────────────────────
    function goTo(newIdx, dir) {
      if (isTransitioning || newIdx === current) return;
      if (newIdx < 0 || newIdx >= total) return;
      isTransitioning = true;

      var oldCard = cards[current];
      var newCard = cards[newIdx];

      // Position new card off-screen (no transition yet)
      newCard.style.transition = "none";
      newCard.style.transform = dir === "forward" ? "translateX(100%)" : "translateX(-100%)";
      newCard.style.opacity = "0";
      newCard.style.pointerEvents = "none";

      // Force layout so browser paints the start position
      newCard.getBoundingClientRect(); // eslint-disable-line @typescript-eslint/no-unused-expressions

      // Enable transitions on both cards
      var trans = "transform " + DURATION + "ms ease, opacity " + DURATION + "ms ease";
      oldCard.style.transition = trans;
      newCard.style.transition = trans;

      // Animate old card OUT
      oldCard.style.transform = dir === "forward" ? "translateX(-100%)" : "translateX(100%)";
      oldCard.style.opacity = "0";
      oldCard.style.pointerEvents = "none";
      oldCard.classList.remove("is-active");

      // Animate new card IN
      newCard.style.transform = "translateX(0)";
      newCard.style.opacity = "1";
      newCard.style.pointerEvents = "auto";
      newCard.classList.add("is-active");

      current = newIdx;
      updateNav(current);
      animateProgress();

      setTimeout(function () {
        isTransitioning = false;
      }, DURATION);
    }

    // ── Tab clicks ───────────────────────────────────────────────
    tabs.forEach(function (tab) {
      tab.addEventListener("click", function () {
        var idx = parseInt(tab.getAttribute("data-index") || "0", 10);
        var dir = idx > current ? "forward" : "backward";
        goTo(idx, dir);
      });
    });

    // ── Arrow clicks ─────────────────────────────────────────────
    if (prevBtn) {
      prevBtn.addEventListener("click", function () {
        goTo(current - 1, "backward");
      });
    }
    if (nextBtn) {
      nextBtn.addEventListener("click", function () {
        goTo(current + 1, "forward");
      });
    }

    // ── Scroll (wheel) intercept ─────────────────────────────────
    // When the projects section is in view, wheel events advance/retreat projects.
    // At the first/last project the normal page scroll is restored.
    var wheelCooldown = false;

    window.addEventListener(
      "wheel",
      function (e) {
        var section = document.getElementById("projects");
        if (!section) return;
        var rect = section.getBoundingClientRect();
        // Section must be substantially in view
        var inView = rect.top < window.innerHeight * 0.65 && rect.bottom > window.innerHeight * 0.35;
        if (!inView || wheelCooldown || isTransitioning) return;

        var delta = e.deltaY;

        if (delta > 20 && current < total - 1) {
          e.preventDefault();
          wheelCooldown = true;
          goTo(current + 1, "forward");
          setTimeout(function () {
            wheelCooldown = false;
          }, DURATION + 150);
        } else if (delta < -20 && current > 0) {
          e.preventDefault();
          wheelCooldown = true;
          goTo(current - 1, "backward");
          setTimeout(function () {
            wheelCooldown = false;
          }, DURATION + 150);
        }
        // If at boundary, don't preventDefault — page scrolls normally
      },
      { passive: false }
    );

    // ── Touch swipe support ──────────────────────────────────────
    var touchStartX = 0;
    var touchStartY = 0;
    var stage = document.getElementById("proj-stage");
    if (stage) {
      stage.addEventListener("touchstart", function (e) {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
      }, { passive: true });

      stage.addEventListener("touchend", function (e) {
        var dx = e.changedTouches[0].clientX - touchStartX;
        var dy = e.changedTouches[0].clientY - touchStartY;
        // Only trigger if horizontal swipe dominates
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
          if (dx < 0) {
            goTo(current + 1, "forward");  // swipe left → next
          } else {
            goTo(current - 1, "backward"); // swipe right → prev
          }
        }
      }, { passive: true });
    }

    // ── Initialise ───────────────────────────────────────────────
    updateNav(0);
    animateProgress();
  });
</script>
