---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              Projects
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="projects-grid">
              {siteConfig.projects.map((project, index) => (
                <div class="project-card">
                  <div class="card-header">
                    <span class="card-number">0{index + 1}</span>
                    {"tag" in project && project.tag && (
                      <span class="card-tag">{project.tag}</span>
                    )}
                  </div>

                  {"category" in project && project.category && (
                    <p class="card-category">{project.category}</p>
                  )}

                  <h3 class="card-title">{project.name}</h3>

                  <p class="card-description">{project.description}</p>

                  {project.skills && project.skills.length > 0 && (
                    <div class="card-skills">
                      {project.skills.map((skill) => (
                        <span class="skill-chip">{skill}</span>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  /* Grid auto-fills — easy to add more cards later */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .project-card {
    position: relative;
    padding: 1.75rem 2rem;
    background: #f9fafb;
    border-radius: 1rem;
    border: 1.5px solid #e5e7eb;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
    z-index: 1;
    pointer-events: auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .project-card:hover {
    transform: translateY(-3px);
    border-color: #2b3fff;
    box-shadow: 0 8px 28px rgba(43, 63, 255, 0.14);
    background: #ffffff;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .card-number {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.78rem;
    color: #2b3fff;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .card-tag {
    display: inline-block;
    padding: 0.2rem 0.7rem;
    background: rgba(43, 63, 255, 0.08);
    color: #2b3fff;
    border: 1px solid rgba(43, 63, 255, 0.2);
    border-radius: 9999px;
    font-size: 0.68rem;
    font-weight: 600;
    font-family: 'IBM Plex Mono', monospace;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .card-category {
    font-size: 0.72rem;
    color: #6b7280;
    font-family: 'IBM Plex Mono', monospace;
    margin-bottom: 0.4rem;
    letter-spacing: 0.03em;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #111827;
    line-height: 1.4;
    margin-bottom: 0.75rem;
  }

  .card-description {
    font-size: 0.875rem;
    color: #4b5563;
    line-height: 1.7;
    margin-bottom: 1.25rem;
    flex: 1;
  }

  .card-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
  }

  .skill-chip {
    padding: 0.2rem 0.55rem;
    background: #111827;
    color: #ffffff;
    border-radius: 0.375rem;
    font-size: 0.68rem;
    font-weight: 500;
    font-family: 'IBM Plex Mono', monospace;
    letter-spacing: 0.02em;
  }
</style>
